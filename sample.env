# PracticeLingo — Environment Variables
# Copy this file to .env.local and fill in real values

# SMTP Configuration (e.g. Zoho Mail, Gmail, SendGrid)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=hello@practicelingo.co.uk
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=PracticeLingo <hello@practicelingo.co.uk>

# Where demo/contact form submissions are delivered
CONTACT_EMAIL=hello@practicelingo.co.uk

# Public site URL (used in auto-reply emails)
NEXT_PUBLIC_SITE_URL=https://practicelingo.co.uk
